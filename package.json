{
  "name": "dav-ai",
  "version": "1.0.2",
  "description": "DAV-M — terminal AI assistant powered by Anthropic, OpenAI, and Google Gemini with MCP support",
  "type": "module",
  "bin": {
    "dav": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run typecheck && npm run build",
    "pack:verify": "npm pack --dry-run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.48",
    "@clack/prompts": "^1.2.0",
    "ai": "^6.0.142",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.0",
    "diff": "^8.0.4",
    "dotenv": "^16.4.5",
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "js-tiktoken": "^1.0.21",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "react": "^18.3.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/update-notifier": "^6.0.8",
    "tsdown": "^0.20.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "terminal",
    "assistant",
    "mcp",
    "model-context-protocol",
    "anthropic",
    "openai",
    "gemini",
    "llm",
    "agent"
  ],
  "homepage": "https://github.com/poaxy/dav-m#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poaxy/dav-m.git"
  },
  "bugs": {
    "url": "https://github.com/poaxy/dav-m/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT"
}
